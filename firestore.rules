rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if
          request.resource.data.keys().hasOnly(["name", "score", "mode", "createdAt"])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 24
          && request.resource.data.score is number
          && request.resource.data.score >= 0
          && request.resource.data.score < 1000000
          && request.resource.data.mode in ["normal", "hard", "skull"]
          && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }
  }
}

/*
  Firebase インデックス設定：
  
  複合検索を行う場合は、以下のインデックスを Firebase Console で作成してください：
  
  1. mode（昇順） + score（降順）
     Collection: scores
     Fields:
       - mode (Ascending)
       - score (Descending)
  
  Firebase Console で作成方法：
  1. https://console.firebase.google.com へアクセス
  2. aomoriapple-48db3 プロジェクトを選択
  3. Firestore Database → Indexes タブ
  4. [複合インデックスを作成] をクリック
  5. Collection: scores
     Field 1: mode (Ascending)
     Field 2: score (Descending)
     を指定して作成
*/
